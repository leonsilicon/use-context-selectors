{
  "name": "es-main-wrapper",
  "version": "0.0.0",
  "description": "Re-exports es-main so you can depend on a single maintained package boundary.",
  "keywords": [
    "es-main",
    "esm",
    "import.meta",
    "node",
    "require.main"
  ],
  "license": "MIT",
  "author": "Leon Silicon",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leonsilicon/use-context-selectors.git",
    "directory": "packages/es-main-wrapper"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp fmt --check && tsc -p tsconfig.json",
    "prepublishOnly": "vp run build",
    "prepare": "vp config"
  },
  "dependencies": {
    "es-main": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@typescript/native-preview": "7.0.0-dev.20260509.2",
    "typescript": "^6.0.3",
    "vite-plus": "^0.1.20"
  }
}
