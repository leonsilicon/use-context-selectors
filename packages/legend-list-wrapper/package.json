{
  "name": "legend-list-wrapper",
  "version": "0.0.0",
  "description": "Re-exports @legendapp/list under a stable package name.",
  "keywords": [
    "flatlist",
    "legend-list",
    "legendapp",
    "react",
    "react-native"
  ],
  "license": "MIT",
  "author": "Leon Silicon",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leonsilicon/use-context-selectors.git",
    "directory": "packages/legend-list-wrapper"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./animated": {
      "types": "./dist/animated.d.mts",
      "import": "./dist/animated.mjs",
      "default": "./dist/animated.mjs"
    },
    "./keyboard": {
      "types": "./dist/keyboard.d.mts",
      "import": "./dist/keyboard.mjs",
      "default": "./dist/keyboard.mjs"
    },
    "./keyboard-controller": {
      "types": "./dist/keyboard-controller.d.mts",
      "import": "./dist/keyboard-controller.mjs",
      "default": "./dist/keyboard-controller.mjs"
    },
    "./reanimated": {
      "types": "./dist/reanimated.d.mts",
      "import": "./dist/reanimated.mjs",
      "default": "./dist/reanimated.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "check": "vp fmt --check && tsc -p tsconfig.json",
    "prepublishOnly": "vp run build",
    "prepare": "vp config"
  },
  "dependencies": {
    "@legendapp/list": "^2.0.19"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@typescript/native-preview": "7.0.0-dev.20260509.2",
    "react": "^19.2.6",
    "react-native": "0.79.2",
    "typescript": "^6.0.3",
    "vite-plus": "^0.1.20"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "packageManager": "pnpm@11.1.1"
}
